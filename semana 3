    <style>
        body {
            background-color: lightcyan; /* Tu color de fondo celeste claro */
            font-family: Arial, sans-serif; /* Tu fuente original */
            padding: 30px;
            margin: 0;
        }

        h1, h2, h3, h4 {
            text-align: center;
            color: darkblue; /* Tu color azul oscuro */
        }

        p {
            text-align: center; 
            font-size: 14px;
            margin-top: 20px;
            line-height: 1.6;
        }

        /* DISEÑO DE LOS TRES CUADROS DE NAVEGACIÓN */
        .contenedor-cuadros {
            display: flex;
            justify-content: center;
            gap: 20px;
            max-width: 900px;
            margin: 30px auto;
            flex-wrap: wrap;
        }

        .tarjeta-enlace {
            background-color: white;
            border: 2px solid darkblue;
            border-radius: 10px;
            padding: 25px;
            text-align: center;
            flex: 1;
            min-width: 200px;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
            text-decoration: none;
            transition: transform 0.2s, box-shadow 0.2s;
        }

        .tarjeta-enlace:hover {
            transform: translateY(-5px);
            box-shadow: 0 6px 12px rgba(0, 0, 0, 0.15);
            background-color: #f0fdfd;
        }

        .tarjeta-enlace h3 {
            margin: 0 0 10px 0;
            font-size: 18px;
            color: darkblue;
        }

        .tarjeta-enlace p {
            margin: 0;
            color: #555;
            font-size: 13px;
        }

        /* TRUCO CSS: OCULTAR LAS SECCIONES POR DEFECTO */
        .seccion-dinamica {
            display: none; /* Hace que el texto no se vea al inicio */
            background-color: rgba(255, 255, 255, 0.7); 
            padding: 30px;
            margin: 40px auto;
            border-radius: 8px;
            max-width: 800px;
            border: 1px dashed darkblue;
            animation: fadeIn 0.5s ease; /* Efecto visual para que aparezca suave */
        }

        /* Muestra la sección SOLO cuando se le hace clic al cuadro correspondiente */
        .seccion-dinamica:target {
            display: block;
        }

        /* Animación suave de aparición */
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        ul {
            max-width: 600px;
            margin: 20px auto;
            text-align: left;
        }

        img {
            display: block;
            margin: 20px auto;
            max-width: 100%;
            height: auto;
            border-radius: 5px;
        }

        .video-container {
            text-align: center;
            margin: 20px 0;
        }

        /* Botón opcional para cerrar o regresar al inicio */
        .btn-cerrar {
            display: block;
            width: fit-content;
            margin: 20px auto 0 auto;
            padding: 8px 15px;
            background-color: darkblue;
            color: white;
            text-decoration: none;
            border-radius: 5px;
            font-size: 12px;
        }
        .btn-cerrar:hover {
            background-color: #0000aa;
        }

        aside {
            background-color: rgba(255, 255, 255, 0.5);
            padding: 20px;
            margin: 40px auto;
            border-radius: 8px;
            max-width: 800px;
        }

        footer {
            text-align: center;
            margin-top: 40px;
            padding-top: 20px;
            border-top: 1px solid darkblue;
        }
    </style>
</head>
